    "description": [
      "◆━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━◆",
      "  CH.04 · THE BREWING STAND",
      "◆━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━◆",
      "",
      "▸ The Brewing Stand is where fermentation meets magic.",
      "  Blaze powder to fuel. Nether Wart to prime.",
      "  Everything else builds on those two.",
      "",
      "◈ POTION PROGRESSION",
      "  └ Awkward Potion: water bottle + nether wart",
