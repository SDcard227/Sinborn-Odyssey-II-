    "description": [
      "◆━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━◆",
      "  CH.07 · MECHANICAL EXPANSION",
      "◆━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━◆",
      "",
      "▸ The Mechanical Expansion scroll covers",
      "  the advanced Create components that complete",
      "  the fully-automated factory.",
      "  Belt. Funnel. Deployer. Arm. You have all of it now.",
      "",
      "◈ ADVANCED CREATE COMPONENTS",
      "  └ Deployer: rotational machine that places/uses",
